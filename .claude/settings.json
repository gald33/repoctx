{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/repoctx-py.sh\" -m repoctx update --from-claude-hook"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/repoctx-py.sh\" -m repoctx hook tool-use"
          }
        ],
        "matcher": "Read|Edit|Write|MultiEdit"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/repoctx-py.sh\" -m repoctx hook prompt-nudge"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/scripts/repoctx-py.sh\" -m repoctx hook stop-check"
          }
        ]
      }
    ]
  }
}
