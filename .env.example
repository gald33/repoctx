# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Load before running commands that need credentials:
#
#   set -a; source .env; set +a
#
# Or use direnv / a per-shell loader of your choice.

# -----------------------------------------------------------------------------
# PyPI API token
# -----------------------------------------------------------------------------
#
# Generate at: https://pypi.org/manage/account/token/
#
# Scope it to the `repoctx-mcp` project (NOT account-wide) so a leaked token
# can't touch anything else. Token strings look like `pypi-AgEIcHlwaS5vcmcCJ...`
# and are ~150+ characters.
#
# What this token is FOR:
#   - Yanking releases:
#       curl -X POST https://pypi.org/manage/project/repoctx-mcp/release/<version>/
#       (use the web UI for now; CLI yank requires a third-party tool)
#   - Inspecting metadata or rare emergency local uploads.
#
# What this token is NOT for:
#   - Regular releases. Those go through `.github/workflows/publish-pypi.yml`
#     via PyPI Trusted Publishing (OIDC) — no token needed, by design. See
#     AGENTS.md "Releasing to PyPI" before considering a local `twine upload`.
#
# The variable names match what twine reads natively (TWINE_USERNAME +
# TWINE_PASSWORD), so any twine invocation auto-picks them up.

TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-PASTE_TOKEN_HERE
