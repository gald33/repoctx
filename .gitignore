.venv/
.pytest_cache/
*.egg-info/
__pycache__/
.worktrees/
.repoctx/
build/
dist/

# Local secrets — PyPI token etc. Never committed; .env.example is the
# template and IS committed.
.env
.env.*
!.env.example

# Claude Code: personal config + transient session state. The committable
# project-level config (.claude/settings.json) — which `repoctx install` itself
# writes — is intentionally NOT ignored.
.claude/*.local.json
.claude/worktrees/
